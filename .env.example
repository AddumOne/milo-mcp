# GitHub — read:repo scope, required for all operations
GITHUB_TOKEN=ghp...

# GitHub — repo scope, required for write tools (create_block, open_pull_request)
GITHUB_WRITE_TOKEN=ghp...

# Anthropic — required for CRAG validation and Self-RAG grading
ANTHROPIC_API_KEY=sk-ant...

# Figma — required for design-to-code tools (Phase 4)
FIGMA_API_KEY=figd_...

# DA — required for DA authoring tools (Phase 5)
DA_API_TOKEN=...

# Milo repo config
MILO_REPO_OWNER=adobecom
MILO_REPO_NAME=milo
MILO_DEFAULT_BRANCH=stage

# RAG config
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
CRAG_THRESHOLD=0.6
SELF_RAG_MAX_ATTEMPTS=2
